// Copy this file to wifi_config.h and fill in your credentials.
// wifi_config.h is gitignored — never commit real credentials.

#pragma once

#define WIFI_SSID     "your-network-name"
#define WIFI_PASSWORD "your-wifi-password"

// MQTT broker — use an IP address or hostname
#define MQTT_HOST     "192.168.1.100"
#define MQTT_PORT     1883

// Optional: leave empty strings to connect without authentication
#define MQTT_USER     ""
#define MQTT_PASSWORD ""

// Topic prefix: events publish to <prefix>/event/<type>
// e.g. "buddy/events/permission", "buddy/events/approval"
#define MQTT_TOPIC_PREFIX "buddy"
